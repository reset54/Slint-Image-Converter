import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component FileList inherits VerticalBox {
    in property <[string]> files;
    in property <bool> processing;

    callback remove-clicked(int);

    padding: 10px;
    spacing: 5px;
    alignment: start; // Critical: packs items from top to bottom

    Text {
        text: "Files in queue: " + root.files.length;
        color: #aaa;
        font-size: 14px;
        horizontal-alignment: center;
    }

    // Spacer between title and list
    Rectangle { height: 5px; }

    for file-path[i] in root.files : Rectangle {
        height: 35px;
        background: #303030;
        border-radius: 2px;

        HorizontalBox {
            padding-left: 10px;
            padding-right: 10px;
            spacing: 10px;

            Text {
                text: file-path;
                vertical-alignment: center;
                overflow: elide;
                font-size: 13px;
                color: #eee;
            }

            Rectangle {} // Spacer

            Button {
                text: "×";
                width: 25px;
                height: 25px;
                enabled: !root.processing;
                clicked => { root.remove-clicked(i); }
            }
        }
    }
}
