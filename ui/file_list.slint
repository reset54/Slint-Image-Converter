import { ScrollView, Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component FileList inherits VerticalBox {
    in property <[string]> files;
    in property <bool> processing;

    callback remove-clicked(int);

    spacing: 5px;

    Text {
        text: "Files in queue: " + root.files.length;
        color: #aaa;
        font-size: 14px;
    }

    Rectangle {
        background: #252525;
        border-radius: 4px;
        min-height: 100px;

        ScrollView {
            viewport-height: root.files.length * 40px;

            for file-path[i] in root.files : HorizontalBox {
                height: 40px;
                padding-left: 10px;
                padding-right: 10px;
                spacing: 10px;

                Text {
                    text: file-path;
                    vertical-alignment: center;
                    overflow: elide;
                    font-size: 13px;
                }

                // Filler to push the button to the right
                Rectangle {}

                Button {
                    text: "×";
                    width: 25px;
                    height: 25px;
                    enabled: !root.processing;
                    clicked => { root.remove-clicked(i); }
                }
            }
        }
    }
}
